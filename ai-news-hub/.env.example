# Copy this file to ".env" and fill in your keys. The .env file is git-ignored.

# Google Gemini - powers the "Ask" agent.
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Tavily - lets the agent search the whole web.
# Get a free key at https://app.tavily.com
TAVILY_API_KEY=

# Optional: which Gemini model to use (default below).
# Other options: gemini-2.5-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash